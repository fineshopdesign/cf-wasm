{
  "name": "@examples/svelte-kit-cloudflare",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "cf:preview": "pnpm run build && wrangler dev",
    "cf:build": "pnpm run build && wrangler deploy --dry-run --outdir=.workers-build",
    "cf:deploy": "pnpm run build && wrangler deploy",
    "cf:types": "wrangler types ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@cf-wasm/og": "workspace:*",
    "@cf-wasm/photon": "workspace:*",
    "@cf-wasm/plugins": "workspace:*",
    "@cf-wasm/resvg": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "vite": "^8.1.4",
    "wrangler": "catalog:"
  }
}
