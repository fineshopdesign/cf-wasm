{
  "name": "@examples/nuxt-cloudflare",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "pnpm run build && wrangler dev",
    "cf:preview": "pnpm run build && wrangler dev",
    "cf:build": "pnpm run build && wrangler deploy --dry-run --outdir=./.workers-build",
    "cf:deploy": "pnpm run build && wrangler deploy",
    "cf:types": "wrangler types ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@cf-wasm/og": "workspace:*",
    "@cf-wasm/photon": "workspace:*",
    "@cf-wasm/plugins": "workspace:*",
    "@cf-wasm/resvg": "workspace:*",
    "nuxt": "^4.4.8",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "h3": "2.0.1-rc.22",
    "nitro-cloudflare-dev": "^0.2.2",
    "nitropack": "^2.13.4",
    "vite": "^7.3.2",
    "wrangler": "catalog:"
  }
}
